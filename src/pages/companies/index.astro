---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allCompanies = await getCollection('companies');
const companies = allCompanies.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="Companies" description="Equity research notes on publicly traded companies">
  <h1>Companies</h1>
  <p style="color: var(--text-muted); font-size: 0.95rem; margin: 0.5rem 0 2.5rem;">
    Equity research notes and financial charts.
  </p>

  {companies.length === 0 ? (
    <p class="empty">No companies yet.</p>
  ) : (
    <ul class="card-list">
      {companies.map(co => (
        <li class="card">
          <a href={`/companies/${co.id}`} class="card-title">
            <span class="ticker-badge">{co.data.ticker}</span>
            {co.data.title}
          </a>
          <span class="card-meta">{co.data.exchange} · {co.data.sector ?? ''} · {fmt(co.data.date)}</span>
          {co.data.description && (
            <span class="card-desc">{co.data.description}</span>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25rem;
  }
  .ticker-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    background: var(--accent);
    color: #fff;
    border-radius: 3px;
    padding: 0.1em 0.45em;
    margin-right: 0.4rem;
    vertical-align: middle;
    position: relative;
    top: -1px;
  }
</style>
