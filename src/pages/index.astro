---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const allCharts = await getCollection('charts');

const recentNotes = allNotes
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const recentCharts = allCharts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title="sendo_akira" description="Study notes and interactive charts">
  <p style="color: var(--text-muted); margin-bottom: 3rem; font-size: 0.95rem;">
    Study notes, charts, and things I'm learning.
  </p>

  <h2>Recent Notes</h2>
  {recentNotes.length === 0 ? (
    <p class="empty">No notes yet.</p>
  ) : (
    <ul class="card-list">
      {recentNotes.map(note => (
        <li class="card">
          <a href={`/notes/${note.id}`} class="card-title">{note.data.title}</a>
          <span class="card-meta">{fmt(note.data.date)}</span>
          {note.data.description && (
            <span class="card-desc">{note.data.description}</span>
          )}
        </li>
      ))}
    </ul>
  )}

  <h2>Charts</h2>
  {recentCharts.length === 0 ? (
    <p class="empty">No charts yet.</p>
  ) : (
    <ul class="card-list">
      {recentCharts.map(chart => (
        <li class="card">
          <a href={`/charts/${chart.id}`} class="card-title">{chart.data.title}</a>
          <span class="card-meta">{fmt(chart.data.date)}</span>
          {chart.data.description && (
            <span class="card-desc">{chart.data.description}</span>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
